                    "type": "string"
                }
            }
        },
        "handlers.TeacherScheduleEntry": {
            "type": "object",
            "properties": {
                "class_name": {
                    "type": "string"
                },
                "period": {
                    "type": "integer"
                },
                "room_num": {
                    "type": "string"
                },
                "school_year": {
                    "type": "string"
                }
            }
        }
    }
}